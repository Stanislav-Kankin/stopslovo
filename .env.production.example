LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TEXT_CHARS=4000
LLM_MAX_FLAGGED_TERMS=20

JWT_SECRET=change-me-to-a-long-random-secret
SECURE_COOKIES=true
ALLOWED_ORIGINS=https://stopslovo.dev-cloud-ksa.ru
FRONTEND_URL=https://stopslovo.dev-cloud-ksa.ru
BACKEND_URL=https://stopslovo.dev-cloud-ksa.ru
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
APP_ENV=production
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://stopslovo.dev-cloud-ksa.ru/pricing
YOOKASSA_WEBHOOK_SECRET=

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

ADMIN_EMAIL=admin@admin.ru
ADMIN_PASSWORD=

SERVER_NAME=stopslovo.dev-cloud-ksa.ru
HTTP_PORT=80
HTTPS_PORT=443

# Укажите реальные пути на VPS. Сертификаты монтируются внутрь nginx read-only.
SSL_CERT_PATH=/etc/letsencrypt/live/stopslovo.dev-cloud-ksa.ru/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/stopslovo.dev-cloud-ksa.ru/privkey.pem
